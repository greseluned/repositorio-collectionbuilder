---
permalink: /assets/data/search-index.json
---
[{% for item in site.data[site.metadata] %}{% if item.objectid %}{
  "id": {{ item.objectid | jsonify }},
  "title": {{ item.title | jsonify }},
  "date": {{ item.date | jsonify }},
  "collection": {{ item.collection | jsonify }},
  "location": {{ item.location | jsonify }},
  "language": {{ item.language | jsonify }},
  "thumb": {{ item.image_thumb | relative_url | jsonify }},
  "transcript": {{ item.object_transcript | jsonify }}
}{% unless forloop.last %},{% endunless %}{% endif %}{% endfor %}]